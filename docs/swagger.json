{
    "swagger": "2.0",
    "info": {
        "description": "API de Reportes generada con Onion Architecture, Unit of Work y Repository Pattern",
        "title": "API REST ServiYa (Reportes)",
        "contact": {},
        "version": "2.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/auth/login": {
            "post": {
                "description": "Inicia sesión en Supabase y devuelve un JWT si el usuario es un administrador",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "autenticacion"
                ],
                "summary": "Iniciar sesión como administrador",
                "parameters": [
                    {
                        "description": "Credenciales del administrador",
                        "name": "credenciales",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.LoginRequestDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.LoginResponseDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/reportes/actividad-usuarios": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Devuelve cuántos usuarios nuevos se registraron y cuántos usuarios activos (con al menos una reserva) hubo en el mes",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reportes"
                ],
                "summary": "Obtiene la actividad de usuarios del mes",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Mes (1-12)",
                        "name": "mes",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Año (ej. 2026)",
                        "name": "anio",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.ActividadUsuariosDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/reportes/admin": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Devuelve el top de prestadores, cantidad de pqrs abiertas y estadísticas de reservas para un mes y año",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reportes"
                ],
                "summary": "Obtiene un reporte consolidado para el administrador",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Mes (1-12)",
                        "name": "mes",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Año (ej. 2026)",
                        "name": "anio",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.ReporteConsolidadoMensualDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/reportes/admin/pdf": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Genera y devuelve un documento PDF con los datos de administrador, actividad y servicios",
                "produces": [
                    "application/pdf"
                ],
                "tags": [
                    "reportes"
                ],
                "summary": "Descarga el reporte general en PDF",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Mes (1-12)",
                        "name": "mes",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Año (ej. 2026)",
                        "name": "anio",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "reporte.pdf",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/reportes/servicios-populares": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Devuelve los 10 servicios con más reservas en el mes y año indicados, incluyendo nombre y categoría",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reportes"
                ],
                "summary": "Obtiene los servicios más solicitados del mes",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Mes (1-12)",
                        "name": "mes",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Año (ej. 2026)",
                        "name": "anio",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.ServicioPopularDTO"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.ActividadUsuariosDTO": {
            "type": "object",
            "properties": {
                "anio": {
                    "type": "integer"
                },
                "mes": {
                    "type": "integer"
                },
                "usuarios_activos": {
                    "type": "integer"
                },
                "usuarios_nuevos": {
                    "type": "integer"
                }
            }
        },
        "domain.LoginRequestDTO": {
            "type": "object",
            "required": [
                "correo",
                "password"
            ],
            "properties": {
                "correo": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "domain.LoginResponseDTO": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_in": {
                    "type": "integer"
                },
                "token_type": {
                    "type": "string"
                }
            }
        },
        "domain.PrestadorTopDTO": {
            "type": "object",
            "properties": {
                "calificacion": {
                    "type": "number"
                },
                "correo_prestador": {
                    "type": "string"
                },
                "id_prestador": {
                    "type": "integer"
                },
                "nombre_prestador": {
                    "type": "string"
                },
                "total_servicios": {
                    "type": "integer"
                }
            }
        },
        "domain.ReporteConsolidadoMensualDTO": {
            "type": "object",
            "properties": {
                "anio": {
                    "type": "integer"
                },
                "mes": {
                    "type": "integer"
                },
                "pqrs_abiertas": {
                    "type": "integer"
                },
                "top_prestadores": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.PrestadorTopDTO"
                    }
                },
                "total_aceptadas": {
                    "type": "integer"
                },
                "total_canceladas": {
                    "type": "integer"
                },
                "total_completadas": {
                    "type": "integer"
                },
                "total_pendientes": {
                    "type": "integer"
                },
                "total_reservas": {
                    "type": "integer"
                }
            }
        },
        "domain.ServicioPopularDTO": {
            "type": "object",
            "properties": {
                "categoria": {
                    "type": "string"
                },
                "id_servicio": {
                    "type": "integer"
                },
                "nombre_servicio": {
                    "type": "string"
                },
                "veces_solicitado": {
                    "type": "integer"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}